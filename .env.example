# Скопируйте этот файл в .env и вставьте токен вашего бота.
# Получить токен можно у @BotFather в Telegram.

BOT_TOKEN=your_telegram_bot_token_here

# Прокси-сервер (необязательно). Укажите, если Telegram заблокирован провайдером.
# Поддерживаемые форматы:
#   PROXY_URL=socks5://user:password@host:port
#   PROXY_URL=socks5://host:port
#   PROXY_URL=http://user:password@host:port
# Оставьте пустым или удалите строку, чтобы не использовать прокси.
PROXY_URL=
